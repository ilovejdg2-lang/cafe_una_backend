# Supabase PostgreSQL (pooler) — equivalente a ConnectionStrings:DefaultConnection en .NET
SUPABASE_HOST=aws-1-us-east-1.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres.PROJECT_REF
SUPABASE_PASSWORD=your-supabase-db-password

# Alternativa: URL completa
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

PORT=5220
JWT_SECRET=your-jwt-secret-here
JWT_ISSUER=CafeUNA
JWT_AUDIENCE=cafe-una-api
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Cafe UNA
CEDULA_PROVIDER=GoMeta
CEDULA_GOMETA_URL=https://apis.gometa.org/cedulas
